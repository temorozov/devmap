  "scripts": {
    "dev": "./scripts/dev-up.sh",
    "dev:up": "./scripts/dev-up.sh",
    "dev:fast": "./scripts/dev-fast.sh",
    "dev:fast:db": "docker compose --env-file .env -f docker-compose.yml -f docker-compose.dev.yml up -d postgres",
    "dev:fast:frontend": "npx nx serve frontend-frontend",
    "dev:mobile": "npx nx serve frontend-frontend --host=0.0.0.0 --port=4200",
    "dev:fast:backend": "./scripts/dev-fast.sh backend",
    "dev:repair-db": "./scripts/dev-repair-prisma.sh",
    "prod": "./deploy.sh",
    "prod:recreate-db": "docker compose --env-file .env.production -f docker-compose.yml down -v && docker compose --env-file .env.production -f docker-compose.yml up -d --build",
    "dev:down": "./scripts/dev-down.sh",
    "prod:down": "docker compose --env-file .env.production -f docker-compose.yml down",
    "format": "prettier --write \"apps/**/*.{ts,html,scss}\"",
    "format:check": "prettier --check \"apps/**/*.{ts,html,scss}\"",
    "build": "nx run-many -t build",
    "lint": "nx run-many -t lint",
    "test": "nx run-many -t test",
    "e2e": "nx run-many -t e2e"
  },
