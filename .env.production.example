NODE_ENV=production

# Public URLs
FRONTEND_URL=https://example.com
FRONTEND_PORT=80
BACKEND_URL=https://example.com
BACKEND_PORT=3000
PORT=3000
API_URL=https://example.com/api
CORS_ORIGINS=https://example.com

# Database
POSTGRES_DB=devmap
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://postgres:change-me@postgres:5432/devmap?schema=public

# Auth
JWT_SECRET=replace-with-a-long-random-string
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://example.com/api/auth/github/callback
GITHUB_WEBHOOK_SECRET=

# Optional OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://example.com/api/auth/google/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=https://example.com/api/auth/discord/callback
OAUTH_FRONTEND_REDIRECT_URL=

# Email (optional — weekly digest + skills-updated notifications)
RESEND_API_KEY=
EMAIL_FROM=DevMap <noreply@yourdomain.com>
EMAIL_CONFIRM_URL=https://example.com/confirm-email

# AI (optional — JD matcher skill inference; falls back to literal matching when unset)
OPENAI_API_KEY=
AI_OPENAI_MODEL=gpt-4o-mini
AI_REQUEST_TIMEOUT_MS=30000
