generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String        @id @default(uuid())
  email                  String?       @unique
  passwordHash           String?
  name                   String?
  googleId               String?       @unique
  discordId              String?       @unique
  githubId               String?       @unique
  githubUsername         String?
  githubAccessToken      String?
  handle                 String?       @unique
  isGuest                Boolean       @default(false)
  isEmailConfirmed       Boolean       @default(true)
  emailConfirmationToken String?
  trees                  Tree[]
  aiBatchJobs            AiBatchJob[]
  githubScans            GitHubScan[]
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
}

model Tree {
  id          String         @id @default(uuid())
  title       String
  sharedToken String?        @unique
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  nodes       Node[]
  activities  TreeActivity[]
  aiBatchJobs AiBatchJob[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model Node {
  id          String   @id @default(uuid())
  treeId      String
  tree        Tree     @relation(fields: [treeId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      Node?    @relation("NodeConnections", fields: [parentId], references: [id])
  children    Node[]   @relation("NodeConnections")
  title       String
  description String?
  icon        String?
  positionX   Float
  positionY   Float
  progress    Int      @default(0)
  level       Int      @default(0)
  maxLevel    Int      @default(3)
  verified    Boolean  @default(false)
  source      String   @default("manual")
  evidence    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TreeActivity {
  id     String   @id @default(uuid())
  treeId String
  tree   Tree     @relation(fields: [treeId], references: [id], onDelete: Cascade)
  date   DateTime @db.Date
  count  Int      @default(1)

  @@unique([treeId, date])
}

model GitHubScan {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scannedAt   DateTime @default(now())
  repoCount   Int      @default(0)
  techCount   Int      @default(0)
  summary     Json?

  @@index([userId, scannedAt])
}

model AiBatchJob {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  treeId          String?
  tree            Tree?    @relation(fields: [treeId], references: [id], onDelete: Cascade)
  kind            String
  status          String
  provider        String   @default("openai")
  model           String
  endpoint        String
  batchId         String?  @unique
  inputFileId     String?
  outputFileId    String?
  errorFileId     String?
  inputJsonlPath  String?
  requestCount    Int      @default(0)
  completedCount  Int      @default(0)
  failedCount     Int      @default(0)
  metadata        Json?
  lastError       String?
  completedAt     DateTime?
  resultsAppliedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([treeId, createdAt])
  @@index([status, createdAt])
}
