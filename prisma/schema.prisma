generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String          @id @default(uuid())
  email             String?         @unique
  name              String?
  githubId          String?         @unique
  githubUsername    String?
  githubAccessToken String?
  handle            String?         @unique
  targetRole        String?
  isGuest           Boolean         @default(false)
  excludedSkills    String[]        @default([])
  trees             Tree[]
  githubScans       GitHubScan[]
  profileViews      ProfileView[]
  githubWebhooks    GitHubWebhook[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model Tree {
  id          String         @id @default(uuid())
  title       String
  sharedToken String?        @unique
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  nodes       Node[]
  activities  TreeActivity[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model Node {
  id          String   @id @default(uuid())
  treeId      String
  tree        Tree     @relation(fields: [treeId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      Node?    @relation("NodeConnections", fields: [parentId], references: [id])
  children    Node[]   @relation("NodeConnections")
  title       String
  description String?
  icon        String?
  positionX   Float
  positionY   Float
  progress    Int      @default(0)
  level       Int      @default(0)
  maxLevel    Int      @default(3)
  verified    Boolean  @default(false)
  source      String   @default("manual")
  evidence    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TreeActivity {
  id     String   @id @default(uuid())
  treeId String
  tree   Tree     @relation(fields: [treeId], references: [id], onDelete: Cascade)
  date   DateTime @db.Date
  count  Int      @default(1)

  @@unique([treeId, date])
}

model GitHubScan {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scannedAt   DateTime @default(now())
  repoCount   Int      @default(0)
  techCount   Int      @default(0)
  summary     Json?

  @@index([userId, scannedAt])
}

model ProfileView {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  viewerIpHash String?
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
}

model GitHubWebhook {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  repoFullName String
  webhookId    Int
  createdAt    DateTime @default(now())

  @@unique([userId, repoFullName])
  @@index([userId])
}
