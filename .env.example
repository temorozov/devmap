NODE_ENV=development

# Public URLs
FRONTEND_URL=http://localhost:4200
FRONTEND_PORT=4200
BACKEND_URL=http://localhost:3000
BACKEND_PORT=3000
PORT=3000
API_URL=http://localhost:3000/api
CORS_ORIGINS=http://localhost:4200

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5433
POSTGRES_DB=devmap
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://postgres:change-me@postgres:5432/devmap?schema=public

# Auth / OAuth
JWT_SECRET=change-me
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/github/callback
GITHUB_WEBHOOK_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=http://localhost:3000/api/auth/discord/callback
OAUTH_FRONTEND_REDIRECT_URL=

# Email (optional — weekly digest + skills-updated notifications)
RESEND_API_KEY=
EMAIL_FROM=DevMap <noreply@yourdomain.com>
EMAIL_CONFIRM_URL=http://localhost:4200/confirm-email

# AI (optional — JD matcher skill inference; falls back to literal matching when unset)
OPENAI_API_KEY=
AI_OPENAI_MODEL=gpt-4o-mini
AI_REQUEST_TIMEOUT_MS=30000
