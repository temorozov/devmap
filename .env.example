NODE_ENV=development

# Public URLs
FRONTEND_URL=http://localhost:4200
FRONTEND_PORT=4200
BACKEND_URL=http://localhost:3000
BACKEND_PORT=3000
PORT=3000
API_URL=http://localhost:3000/api
CORS_ORIGINS=http://localhost:4200

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5433
POSTGRES_DB=skill_tree
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://postgres:change-me@postgres:5432/skill_tree?schema=public

# Auth / OAuth
JWT_SECRET=change-me
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/github/callback
GITHUB_WEBHOOK_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=http://localhost:3000/api/auth/discord/callback

# Email (optional — digest + skills-updated emails)
EMAIL_FROM=DevMap <onboarding@resend.dev>
RESEND_API_KEY=

# AI (optional — skill map generation)
OPENAI_API_KEY=
AI_OPENAI_MODEL=gpt-4o-mini
AI_BATCH_OPENAI_MODEL=gpt-4o-mini
AI_REQUEST_TIMEOUT_MS=30000
AI_PROVIDER_RETRY_COUNT=1
AI_PROVIDER_RETRY_DELAY_MS=1200
YOUTUBE_API_KEY=
AI_YOUTUBE_REQUEST_TIMEOUT_MS=2500
